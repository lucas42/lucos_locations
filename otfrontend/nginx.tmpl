worker_processes 1;
events {
	worker_connections 1024;
}
http {
	upstream otrecorder {
		server ${SERVER_HOST}:${SERVER_PORT};
	}
	upstream oauth2proxy {
		server ${OAUTH2_PROXY_HOST}:${OAUTH2_PROXY_PORT};
	}
	server {
		listen ${LISTEN_PORT};
		listen [::]:${LISTEN_PORT};
		root /usr/share/nginx/html;
		location / {
			rewrite ^/$ /map/ redirect;
		}

		# Internal subrequest oauth2-proxy uses to authorise every other
		# location below. Not directly reachable from outside.
		location = /oauth2/auth {
			internal;
			proxy_pass              http://oauth2proxy;
			proxy_set_header        Host $host;
			proxy_set_header        X-Real-IP $remote_addr;
			proxy_set_header        X-Forwarded-For $proxy_add_x_forwarded_for;
			proxy_set_header        X-Forwarded-Proto $http_x_forwarded_proto;
			proxy_set_header        X-Forwarded-Uri $request_uri;
			proxy_set_header        Content-Length "";
			proxy_pass_request_body off;
		}

		# Login/callback/sign-out dance — must stay reachable without auth.
		location /oauth2/ {
			proxy_pass              http://oauth2proxy;
			proxy_set_header        Host $host;
			proxy_set_header        X-Real-IP $remote_addr;
			proxy_set_header        X-Forwarded-For $proxy_add_x_forwarded_for;
			proxy_set_header        X-Forwarded-Proto $http_x_forwarded_proto;
			proxy_set_header        X-Auth-Request-Redirect $request_uri;
		}

		# owntracks/recorder's /api/0/kill deletes stored location history.
		# locations:read is meant to be read-only, so this is explicitly
		# denied regardless of scope until a write-capable scope exists
		# (see discussion on lucas42/lucos_locations#92). More specific
		# than the /owntracks/api/ location below, so nginx matches this
		# one first.
		location /owntracks/api/0/kill {
			return 403;
		}
		location /owntracks/api/ {
			auth_request      /oauth2/auth;
			auth_request_set  $auth_cookie $upstream_http_set_cookie;
			add_header        Set-Cookie $auth_cookie;
			error_page 401 =403      /oauth2/sign_in;
			proxy_pass http://otrecorder/api/;
		}
		location /owntracks/ws/ {
			auth_request      /oauth2/auth;
			auth_request_set  $auth_cookie $upstream_http_set_cookie;
			add_header        Set-Cookie $auth_cookie;
			error_page 401 =403      /oauth2/sign_in;
			proxy_pass http://otrecorder/ws/;
			proxy_http_version 1.1;
			proxy_set_header Upgrade $http_upgrade;
			proxy_set_header Connection upgrade;
		}
		location /map {
			auth_request      /oauth2/auth;
			auth_request_set  $auth_cookie $upstream_http_set_cookie;
			add_header        Set-Cookie $auth_cookie;
			# Document-navigation path only (lucas42/lucos_locations#99): skip the
			# oauth2-proxy sign-in interstitial and bounce straight to aithne. The
			# bare `=` (no status code) preserves oauth2-proxy's own 302 response
			# from /oauth2/start, rather than rewriting it to 403 like the API/WS
			# locations below — a redirect is the right response shape here because
			# this is a top-level browser navigation, not a fetch/WebSocket call.
			error_page 401 =         /oauth2/start;
			include /etc/nginx/mime.types;
			rewrite ^/map/(.+) /$1         break;
			rewrite ^/map/$    /index.html break;
			rewrite ^/map$     /map/       redirect;
		}

		# HTTP Mode — device publish path. Stays on credential auth: a phone
		# can't do an interactive OIDC login. This is the only reason
		# auth_basic still needs declaring explicitly anywhere in this
		# server block — it used to be inherited from a server-level
		# directive that also (silently) covered every other location.
		location /owntracks/pub {
			auth_basic              "OwnTracks pub";
			auth_basic_user_file    /etc/nginx/owntracks.htpasswd;
			proxy_pass              http://otrecorder/pub;
			proxy_http_version      1.1;
			proxy_set_header        Host $host;
			proxy_set_header        X-Forwarded-For $proxy_add_x_forwarded_for;
			proxy_set_header        X-Real-IP $remote_addr;

			# Optionally force Recorder to use username from Basic
			# authentication user. Whether or not client sets
			# X-Limit-U and/or uses ?u= parameter, the user will
			# be set to $remote_user.
			proxy_set_header        X-Limit-U $remote_user;
		}

		# OwnTracks Recorder Views (requires /view, /static, /utils)
		location /owntracks/view/ {
			auth_request            /oauth2/auth;
			auth_request_set        $auth_cookie $upstream_http_set_cookie;
			add_header              Set-Cookie $auth_cookie;
			error_page 401 =403      /oauth2/sign_in;
			proxy_buffering         off;            # Chrome
			proxy_pass              http://otrecorder/view/;
			proxy_http_version      1.1;
			proxy_set_header        Host $host;
			proxy_set_header        X-Forwarded-For $proxy_add_x_forwarded_for;
			proxy_set_header        X-Real-IP $remote_addr;
		}
		location /owntracks/static/ {
			auth_request            /oauth2/auth;
			auth_request_set        $auth_cookie $upstream_http_set_cookie;
			add_header              Set-Cookie $auth_cookie;
			error_page 401 =403      /oauth2/sign_in;
			proxy_pass              http://otrecorder/static/;
			proxy_http_version      1.1;
			proxy_set_header        Host $host;
			proxy_set_header        X-Forwarded-For $proxy_add_x_forwarded_for;
			proxy_set_header        X-Real-IP $remote_addr;
		}
		location /owntracks/utils/ {
			auth_request            /oauth2/auth;
			auth_request_set        $auth_cookie $upstream_http_set_cookie;
			add_header              Set-Cookie $auth_cookie;
			error_page 401 =403      /oauth2/sign_in;
			proxy_pass              http://otrecorder/utils/;
			proxy_http_version      1.1;
			proxy_set_header        Host $host;
			proxy_set_header        X-Forwarded-For $proxy_add_x_forwarded_for;
			proxy_set_header        X-Real-IP $remote_addr;
		}
		location /_info {
			auth_basic off;
			proxy_pass http://127.0.0.1:8080/_info;
		}

		absolute_redirect off;
		gzip on;
		gzip_vary on;
		gzip_proxied any;
		gzip_comp_level 6;
		gzip_buffers 16 8k;
		gzip_http_version 1.1;
		gzip_types text/plain text/css application/json application/javascript text/javascript;
		proxy_read_timeout 600;
	}
}
